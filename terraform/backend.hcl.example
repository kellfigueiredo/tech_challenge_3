# Copie para backend.hcl (não commitar segredos) e rode:
#   terraform init -backend-config backend.hcl -reconfigure
#
# Crie o bucket S3 manualmente (Academy costuma exigir) e habilite versionamento.

bucket         = "terraformbucket-fiap-ch3"
key            = "togglemaster/fase3/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
# Terraform 1.10+: use_lockfile = true
